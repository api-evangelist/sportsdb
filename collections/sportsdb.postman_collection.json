          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/{{apiKey}}/eventsnext.php?id=133602",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiKey}}", "eventsnext.php"],
              "query": [{ "key": "id", "value": "133602" }]
