          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/{{apiKey}}/search_all_seasons.php?id=4328",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiKey}}", "search_all_seasons.php"],
              "query": [{ "key": "id", "value": "4328" }]
            }
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
